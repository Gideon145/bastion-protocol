# Bastion Protocol — Environment Variables
# Copy this to .env and fill in your values

# Robinhood Chain (via Alchemy)
# Get your free key: https://dashboard.alchemy.com/signup
ALCHEMY_API_KEY=your-alchemy-key-here
ROBINHOOD_RPC=https://robinhood-testnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ROBINHOOD_WS=wss://robinhood-testnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ROBINHOOD_CHAIN_ID=46630

# Agent wallet (create one, get test ETH from faucet)
AGENT_PRIVATE_KEY=0x...
AGENT_ADDRESS=0x...

# Deployed contract addresses (after deploy)
DETECTION_REGISTRY_ADDRESS=0x...

# Telegram alerts
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# AI verification (Gemini)
GEMINI_API_KEY=your-gemini-key

# Gas Manager policy ID (from Alchemy dashboard)
GAS_MANAGER_POLICY_ID=your-policy-id
